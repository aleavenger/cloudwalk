# Demo-only local defaults for reviewer one-click setup.
# These values are intentionally non-secret and for localhost usage only.

MONITORING_API_KEY=reviewer-local-demo-key
TEAM_NOTIFICATION_WEBHOOK_URL=
TEAM_NOTIFICATION_TIMEOUT_SECONDS=5
DECISION_ENGINE_MODE=local
DECISION_LOOKBACK_MINUTES=15
DECISION_FORECAST_HORIZON_MINUTES=30
DECISION_FORECAST_STEP_MINUTES=5
DECISION_MIN_HISTORY_POINTS=1
EXTERNAL_AI_PROVIDER=
EXTERNAL_AI_MODEL=
EXTERNAL_AI_API_KEY=
EXTERNAL_AI_BASE_URL=
EXTERNAL_AI_TIMEOUT_SECONDS=10

API_HOST=0.0.0.0
# Host-side API port only (container internal port remains 8000).
API_PORT=8000
MAX_MONITOR_REQUEST_BYTES=65536

GRAFANA_PORT=3000
TEAM_RECEIVER_PORT=8010
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ANONYMOUS_ENABLED=true
GRAFANA_INFINITY_PLUGIN_VERSION=3.6.0
