# Demo-only local defaults for reviewer one-click setup.
# These values are intentionally non-secret and for localhost usage only.

MONITORING_API_KEY=reviewer-local-demo-key

API_HOST=0.0.0.0
# Host-side API port only (container internal port remains 8000).
API_PORT=8000
MAX_MONITOR_REQUEST_BYTES=65536

GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_INFINITY_PLUGIN_VERSION=3.6.0
